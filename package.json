{
  "name": "story-of-turnips",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A cozy browser farming-adventure toy.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "phaser": "^3.80.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.60.1",
    "vite": "^5.4.2",
    "vitest": "^2.0.5"
  }
}
